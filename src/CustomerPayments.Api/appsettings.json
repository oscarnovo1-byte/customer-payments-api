{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=customer-payments.db"
  },
  "Application": {
    "Name": "Customer Payments API",
    "Version": "v1",
    "Description": "Sample REST API for managing customers and their payments using ASP.NET Core, EF Core, FluentValidation and layered architecture."
  },
  "Jwt": {
    "Issuer": "CustomerPayments.Api",
    "Audience": "CustomerPayments.Client",
    "SecretKey": "",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "DemoUser": {
    "UserId": "1",
    "Email": "admin@customerpayments.com",
    "Password": "",
    "Role": "Admin"
  }
}
